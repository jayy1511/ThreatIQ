# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Internal service authentication
# Shared secret — must match the value set in the backend gateway
# Generate a strong random value for production (e.g., python -c "import secrets; print(secrets.token_urlsafe(32))")
ANALYSIS_SERVICE_API_KEY=

# Service configuration
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8010

# Environment
ENVIRONMENT=development
